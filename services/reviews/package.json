{
  "name": "reviews-service",
  "version": "1.0.0",
  "description": "Reviews microservice for admin-propiedades — manages property reviews and star ratings",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback"
  },
  "dependencies": {
    "@types/cors": "^2.8.19",
    "cors": "^2.8.6",
    "express": "4.19.2",
    "isomorphic-dompurify": "2.16.0",
    "knex": "3.1.0",
    "pg": "8.12.0",
    "pino": "9.3.2",
    "pino-http": "10.2.0",
    "swagger-ui-express": "5.0.1",
    "yamljs": "0.3.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/jest": "29.5.12",
    "@types/node": "20.14.11",
    "@types/pg": "8.11.6",
    "@types/supertest": "6.0.2",
    "@types/swagger-ui-express": "4.1.6",
    "@types/yamljs": "0.2.34",
    "@typescript-eslint/eslint-plugin": "7.16.1",
    "@typescript-eslint/parser": "7.16.1",
    "eslint": "8.57.0",
    "fast-check": "3.20.0",
    "jest": "29.7.0",
    "prettier": "3.3.3",
    "supertest": "7.0.0",
    "ts-jest": "29.2.2",
    "ts-node": "10.9.2",
    "ts-node-dev": "2.0.0",
    "typescript": "5.5.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
