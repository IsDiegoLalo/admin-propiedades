{
  "name": "properties-service",
  "version": "1.0.0",
  "description": "Microservicio de administración de propiedades de alquiler",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "migrate": "knex migrate:latest --knexfile src/db/knexfile.ts"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "4.19.2",
    "isomorphic-dompurify": "2.15.0",
    "knex": "3.1.0",
    "mongoose": "8.5.1",
    "multer": "1.4.5-lts.1",
    "pg": "8.12.0",
    "pino": "9.3.2",
    "swagger-ui-express": "5.0.1",
    "uuid": "10.0.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "4.17.21",
    "@types/jest": "29.5.12",
    "@types/multer": "1.4.11",
    "@types/node": "20.14.12",
    "@types/pg": "8.11.6",
    "@types/supertest": "6.0.2",
    "@types/swagger-ui-express": "4.1.6",
    "@types/uuid": "10.0.0",
    "fast-check": "3.21.0",
    "jest": "29.7.0",
    "supertest": "7.0.0",
    "ts-jest": "29.2.2",
    "ts-node-dev": "2.0.0",
    "typescript": "5.5.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
