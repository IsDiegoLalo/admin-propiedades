# =============================================================
# Variables de entorno — admin-propiedades
# Copiar a .env y completar los valores reales (nunca commitear .env)
# =============================================================

# ---- Properties Service ----
PROPERTIES_PORT=3001
PROPERTIES_POSTGRES_HOST=properties-postgres
PROPERTIES_POSTGRES_PORT=5432
PROPERTIES_POSTGRES_DB=properties_db
PROPERTIES_POSTGRES_USER=properties_user
PROPERTIES_POSTGRES_PASSWORD=changeme_properties

MONGO_URI=mongodb://properties-mongo:27017/properties_docs

REVIEWS_SERVICE_URL=http://reviews-service:3003

PHOTO_MAX_SIZE_BYTES=10485760

# ---- Reservations Service ----
RESERVATIONS_PORT=3002
RESERVATIONS_POSTGRES_HOST=reservations-postgres
RESERVATIONS_POSTGRES_PORT=5432
RESERVATIONS_POSTGRES_DB=reservations_db
RESERVATIONS_POSTGRES_USER=reservations_user
RESERVATIONS_POSTGRES_PASSWORD=changeme_reservations

PROPERTIES_SERVICE_URL=http://properties-service:3001

# 0.0 = nunca falla, 1.0 = siempre falla (para tests)
PAYMENT_MOCK_FAILURE_RATE=0

# ---- Reviews Service ----
REVIEWS_PORT=3003
REVIEWS_POSTGRES_HOST=reviews-postgres
REVIEWS_POSTGRES_PORT=5432
REVIEWS_POSTGRES_DB=reviews_db
REVIEWS_POSTGRES_USER=reviews_user
REVIEWS_POSTGRES_PASSWORD=changeme_reviews

# ---- Logging (compartido) ----
LOG_LEVEL=info

# ---- Frontend (build-time, prefijo VITE_) ----
VITE_PROPERTIES_API_URL=http://localhost:3001
VITE_RESERVATIONS_API_URL=http://localhost:3002
VITE_REVIEWS_API_URL=http://localhost:3003
